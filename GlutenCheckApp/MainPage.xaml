<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GlutenCheckApp.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Button
                x:Name="CounterBtn"
                Text="Kolla gluten" 
                HorizontalOptions="Fill"
                Command="{Binding CheckGlutenCommand}"
                />
            
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
